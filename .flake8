[flake8]
# Codes intentionally ignored:
#   E203 - whitespace before ':' (conflicts with black)
#   W503 - line break before binary operator (black-compatible)
max-line-length = 100
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    venv,
    .venv,
    build,
    dist,
    reports,
    .pytest_cache
# __init__.py files frequently re-export symbols, so ignore "imported but unused".
per-file-ignores =
    __init__.py:F401
