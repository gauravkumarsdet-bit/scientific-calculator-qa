# Sample environment file. Copy to `.env` and tweak.
# (`.env` is gitignored — never commit secrets or local overrides.)

# --- Target under test ---------------------------------------------------
BASE_URL=https://rbihubcodechallenge.github.io/calculator/index.html

# --- Browser settings ----------------------------------------------------
BROWSER=chrome
HEADLESS=true
WINDOW_WIDTH=1280
WINDOW_HEIGHT=800

# --- Waits & timeouts (seconds) ------------------------------------------
IMPLICIT_WAIT=0
EXPLICIT_WAIT=10
PAGE_LOAD_TIMEOUT=30

# --- Reporting -----------------------------------------------------------
SCREENSHOT_ON_FAILURE=true
